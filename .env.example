# Supabase Credentials
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Gemini API Key (للتوليد في الواجهة أو للتمرير للخلفية)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Cloudflare R2 Config (تخزين الصور والملفات)
VITE_R2_ACCOUNT_ID=your-cloudflare-account-id
VITE_R2_ACCESS_KEY_ID=your-r2-access-key-id
VITE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
VITE_R2_BUCKET_NAME=your-bucket-name
VITE_R2_PUBLIC_URL=https://assets.yourdomain.com

# 4. مفاتيح خدمات التعليق الصوتي البديلة الفائقة الواقعية (تفعيل أي منها بالرغبة)
VITE_ELEVENLABS_API_KEY=your-elevenlabs-api-key
VITE_AZURE_SPEECH_KEY=your-azure-speech-key
VITE_AZURE_SPEECH_REGION=your-azure-speech-region (e.g. eastus)
VITE_OPENAI_API_KEY=your-openai-api-key

